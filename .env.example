# Supabase project settings (Project Settings -> API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret for POST /api/packs (sync from GitHub pack index).
SYNC_TOKEN=generate-a-random-string

# Optional: override the GitHub pack index URL (defaults to
# DSB-117/brainblast-pack-registry/main/packs.json)
# PACK_REGISTRY_INDEX_URL=https://raw.githubusercontent.com/DSB-117/brainblast-pack-registry/main/packs.json

# Optional: Solana RPC endpoint used by the stake indexer (defaults to the
# public mainnet-beta endpoint, which is rate-limited — recommend a paid RPC
# provider for production).
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── Distribution endpoint (R3): /api/catalog, /api/feed ──────────────────────
# The TRUSTED distributor ed25519 address. GET /api/feed verifies presented
# grants against this with NO shared secret. Generate the identity OFFLINE with
# `brainblast grant keygen` — publish .address here, keep .secretKey offline for
# issuing grants (`brainblast grant issue`). Without this set, only the public
# catalog + anonymous sample feed work.
BRAINBLAST_MARKET_PUBKEY=

# Optional legacy shared secret — only if you issue hmac-sha256 grants instead of
# ed25519. ed25519 (above) is recommended.
# BRAINBLAST_MARKET_SECRET=

# Optional: comma-separated VTI lot URL(s) the endpoint serves. Default: the
# v0.1.0 full lot from the brainblast repo on main.
# VTI_SOURCE_URL=https://raw.githubusercontent.com/DSB-117/brainblast/main/datasets/v0.1.0/full/vti.jsonl
